# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Built-in Gemini API Key (encrypted, base64 of reversed string for basic obfuscation)
# Generate your own: take your Gemini API key, reverse the string, then base64 encode it
BUILTIN_GEMINI_API_KEY=your-base64-encoded-gemini-key-here
BUILTIN_KEY_ACCESS_PASSWORD=your-password-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
